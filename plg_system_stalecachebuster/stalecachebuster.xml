        <language tag="it-IT">it-IT/plg_system_stalecachebuster.ini</language>
        <language tag="it-IT">it-IT/plg_system_stalecachebuster.sys.ini</language>
        <language tag="ja-JP">ja-JP/plg_system_stalecachebuster.ini</language>
