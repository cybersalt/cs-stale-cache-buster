        <language tag="zh-CN">zh-CN/plg_system_stalecachebuster.sys.ini</language>
    </languages>

    <config>
        <fields name="params">
            <fieldset name="basic" addfieldprefix="Cybersalt\Plugin\System\StaleCacheBuster\Field">
                <field
                    name="no_cache_admin"
                    type="radio"
                    label="PLG_SYSTEM_STALECACHEBUSTER_NO_CACHE_ADMIN_LABEL"
                    description="PLG_SYSTEM_STALECACHEBUSTER_NO_CACHE_ADMIN_DESC"
                    default="0"
                    class="btn-group btn-group-yesno"
                >
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field
                    name="debug_mode"
                    type="radio"
                    label="PLG_SYSTEM_STALECACHEBUSTER_DEBUG_MODE_LABEL"
                    description="PLG_SYSTEM_STALECACHEBUSTER_DEBUG_MODE_DESC"
                    default="0"
                    class="btn-group btn-group-yesno"
                >
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field
                    name="scan_templates"
                    type="Templatescanbutton"
                    label="PLG_SYSTEM_STALECACHEBUSTER_SCAN_TEMPLATES_LABEL"
                    description=""
                />
            </fieldset>
            <fieldset name="logging" label="PLG_SYSTEM_STALECACHEBUSTER_LOGGING_FIELDSET" addfieldprefix="Cybersalt\Plugin\System\StaleCacheBuster\Field">
                <field
                    name="enable_logging"
                    type="radio"
                    label="PLG_SYSTEM_STALECACHEBUSTER_ENABLE_LOGGING_LABEL"
                    description="PLG_SYSTEM_STALECACHEBUSTER_ENABLE_LOGGING_DESC"
                    default="0"
                    class="btn-group btn-group-yesno"
                >
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>
                <field
                    name="log_viewer"
                    type="Viewerbutton"
                    label="PLG_SYSTEM_STALECACHEBUSTER_LOG_VIEWER_LABEL"
                    description=""
                />
            </fieldset>
        </fields>
    </config>

    <scriptfile>script.php</scriptfile>

    <updateservers>
        <server type="extension" priority="1" name="CS Stale Cache Buster Updates">https://raw.githubusercontent.com/cybersalt/cs-stale-cache-buster/main/updates.xml</server>
    </updateservers>
</extension>
