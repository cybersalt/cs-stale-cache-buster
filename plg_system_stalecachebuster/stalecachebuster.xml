        <language tag="nl-NL">nl-NL/plg_system_stalecachebuster.ini</language>
        <language tag="nl-NL">nl-NL/plg_system_stalecachebuster.sys.ini</language>
        <language tag="pl-PL">pl-PL/plg_system_stalecachebuster.ini</language>
        <language tag="pl-PL">pl-PL/plg_system_stalecachebuster.sys.ini</language>
        <language tag="pt-BR">pt-BR/plg_system_stalecachebuster.ini</language>
